    "@angular/router": "^22.0.6",
    "@ngrx/entity": "^21.1.1",
    "@ngrx/signals": "^21.1.1",
    "echarts": "^6.1.0",
    "highcharts": "^13.0.0",
    "rxjs": "~7.8.2",
    "scichart": "^5.2.45",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@analogjs/platform": "^2.6.3",
    "@analogjs/vite-plugin-angular": "^2.6.3",
    "@analogjs/vitest-angular": "^2.6.3",
